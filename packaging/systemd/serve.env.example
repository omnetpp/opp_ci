# /etc/opp_ci/serve.env — environment for opp_ci-serve.service.
# Optional: this file is referenced with EnvironmentFile=-/etc/opp_ci/serve.env,
# so it may be absent.
# Mode 0640, owned by root:opp_ci (contains GitHub secrets).

# Bind address and port. Defaults: 127.0.0.1:8080.
# When behind a reverse proxy, keep host bound to 127.0.0.1.
# To accept direct connections, set host to 0.0.0.0.
#OPP_CI_SERVE_HOST=127.0.0.1
#OPP_CI_SERVE_PORT=8080

# Public URL announced to workers and used by --remote.
#OPP_CI_COORDINATOR_URL=https://ci.example.org

# GitHub integration (optional).
#OPP_CI_GITHUB_TOKEN=
#OPP_CI_GITHUB_WEBHOOK_SECRET=
#OPP_CI_GITHUB_STATUS_CONTEXT=opp_ci

# Fine-grained PAT with Actions:Write for the ci-notes workflow.
#OPP_CI_GITHUB_ACTIONS_TOKEN=
