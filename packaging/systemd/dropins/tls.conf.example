# /etc/systemd/system/opp_ci-serve.service.d/tls.conf
#
# Drop-in that activates native TLS in opp_ci-serve. Rename this file
# from tls.conf.example to tls.conf to apply, then:
#   sudo systemctl daemon-reload
#   sudo systemctl restart opp_ci-serve.service
#
# Cert and key paths come from OPP_CI_SERVE_TLS_{CERT,KEY}_FILE in
# /etc/opp_ci/serve.env. This drop-in only handles the systemd-side
# concerns: privileged-port binding and (optionally) credential isolation.

[Service]
# Bind 443 without running as root. Compatible with NoNewPrivileges=true:
# ambient capabilities are granted at exec, not "gained" later.
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE

# ── Key handling: option A (default) vs option B (hardened) ──────────
#
# Option A: serve reads the key directly from /etc/opp_ci/tls/privkey.pem.
# Requires the file to be mode 0640 with group opp_ci. This is what
# `opp_ci tls-selfsign` and the documented certbot deploy hook produce.
#
# Option B: keep the key root-owned at 0600 and have systemd hand a copy
# to the unit on each start via $CREDENTIALS_DIRECTORY. Requires systemd
# ≥ 250 (Ubuntu 24.04+; 22.04 ships 249 → use option A there).
# To enable: uncomment the LoadCredential= line below, then change
# OPP_CI_SERVE_TLS_KEY_FILE in serve.env to
#   ${CREDENTIALS_DIRECTORY}/privkey.pem
#
# LoadCredential=privkey.pem:/etc/opp_ci/tls/privkey.pem
