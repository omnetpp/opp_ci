# /etc/opp_ci/workers/<NAME>.env — environment for one
# opp_ci-worker@<NAME>.service instance.
# Mode 0600, owned by opp_ci:opp_ci (contains a worker token).

# Coordinator URL the worker polls. Required.
OPP_CI_COORDINATOR_URL=https://ci.example.org

# Worker token produced by `opp_ci worker register`. Required.
OPP_CI_WORKER_TOKEN=REPLACE_ME

# Optional tuning.
#OPP_CI_WORKER_POLL_INTERVAL=10
#OPP_CI_WORKER_HEARTBEAT_INTERVAL=30

# TLS — only needed when the coordinator uses a non-public CA (Cloudflare
# Origin Certificate accessed via the origin's IP, self-signed lab cert,
# internal corporate CA). Workers that go through Cloudflare's edge or
# any other publicly-trusted endpoint should leave both unset and let
# the system CA store handle verification.
#OPP_CI_TLS_CA_BUNDLE=/etc/opp_ci/tls/cloudflare-origin-ca.pem
#
# Dev only: skip TLS verification entirely. Logs a warning each restart.
#OPP_CI_TLS_INSECURE=0
