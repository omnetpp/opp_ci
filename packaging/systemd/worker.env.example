# /etc/opp_ci/workers/<NAME>.env — environment for one
# opp_ci-worker@<NAME>.service instance.
# Mode 0600, owned by opp_ci:opp_ci (contains a worker token).

# Coordinator URL the worker polls. Required.
OPP_CI_COORDINATOR_URL=https://ci.example.org

# Worker token produced by `opp_ci worker register`. Required.
OPP_CI_WORKER_TOKEN=REPLACE_ME

# Optional tuning.
#OPP_CI_WORKER_POLL_INTERVAL=10
#OPP_CI_WORKER_HEARTBEAT_INTERVAL=30
