# /etc/opp_ci/opp_ci.env — shared environment for opp_ci serve and workers.
# This file is read by every opp_ci systemd unit.
# Mode 0640, owned by root:opp_ci.

# SQLAlchemy connection string. SQLite is fine for a single-host
# coordinator; use PostgreSQL for shared deployments.
#OPP_CI_DATABASE_URL=sqlite:////var/lib/opp_ci/opp_ci.db
#OPP_CI_DATABASE_URL=postgresql://opp_ci:secret@localhost/opp_ci

# Parent directory holding each project's working tree
# (i.e. $OPP_CI_PROJECT_DIR/<project>). Workers read this; serve mostly
# does not. Leave unset to use the unit's WorkingDirectory.
#OPP_CI_PROJECT_DIR=/var/lib/opp_ci/projects

# Cache for opp_env GitHub clones.
#OPP_CI_CACHE_DIR=/var/lib/opp_ci/cache

# Default platform spec for auto-generated matrices.
#OPP_CI_REFERENCE_PLATFORM=Ubuntu 24.04/gcc-13
