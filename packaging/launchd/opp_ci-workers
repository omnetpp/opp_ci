#!/bin/bash
# opp_ci-workers {start|stop|restart|status} — umbrella control for every
# opp_ci worker LaunchDaemon on this host. This is the macOS analogue of
# `systemctl {start,stop,…} opp_ci.target`: launchd has no target/umbrella
# concept, so we just iterate the rendered per-worker plists.
#
# Installed to /opt/opp_ci/bin/opp_ci-workers by packaging/launchd/install.sh.
# Run as root (launchctl system-domain operations require it).
set -euo pipefail

DAEMON_DIR="/Library/LaunchDaemons"
PREFIX="org.omnetpp.opp_ci.worker."

usage() {
    echo "usage: opp_ci-workers {start|stop|restart|status}" >&2
    exit 2
}

[ $# -eq 1 ] || usage
action="$1"

if [ "$(uname)" != "Darwin" ]; then
    echo "opp_ci-workers: macOS only (this is the launchd umbrella; on Linux use systemctl opp_ci.target)" >&2
    exit 1
fi
if [ "${EUID:-$(id -u)}" -ne 0 ]; then
    echo "opp_ci-workers: must run as root (try: sudo $0 $action)" >&2
    exit 1
fi

# Collect the installed worker plists. nullglob via the find fallback so an
# empty dir doesn't leave the literal glob pattern.
plists=()
for p in "$DAEMON_DIR/$PREFIX"*.plist; do
    [ -e "$p" ] && plists+=("$p")
done
if [ "${#plists[@]}" -eq 0 ]; then
    echo "No opp_ci worker daemons installed in $DAEMON_DIR" >&2
    exit 0
fi

# Map a plist path to its launchd service target (system/<label>).
label_of() {
    local base
    base="$(basename "$1" .plist)"
    echo "system/$base"
}

case "$action" in
    start)
        for p in "${plists[@]}"; do
            echo "==> bootstrap $(basename "$p")"
            launchctl bootstrap system "$p" 2>/dev/null \
                || echo "    (already loaded)"
        done
        ;;
    stop)
        for p in "${plists[@]}"; do
            echo "==> bootout $(basename "$p")"
            launchctl bootout "$(label_of "$p")" 2>/dev/null \
                || echo "    (not loaded)"
        done
        ;;
    restart)
        for p in "${plists[@]}"; do
            echo "==> kickstart -k $(basename "$p")"
            # kickstart -k restarts an already-loaded job; if it isn't
            # loaded yet, bootstrap it instead.
            launchctl kickstart -k "$(label_of "$p")" 2>/dev/null \
                || launchctl bootstrap system "$p" 2>/dev/null \
                || echo "    (could not (re)start)"
        done
        ;;
    status)
        for p in "${plists[@]}"; do
            tgt="$(label_of "$p")"
            # `launchctl print` is verbose; pull the state + PID lines.
            if out="$(launchctl print "$tgt" 2>/dev/null)"; then
                state="$(printf '%s\n' "$out" | awk -F'= ' '/^[[:space:]]*state = /{print $2; exit}')"
                pid="$(printf '%s\n' "$out" | awk -F'= ' '/^[[:space:]]*pid = /{print $2; exit}')"
                printf '%-50s state=%-12s pid=%s\n' "$(basename "$p" .plist)" "${state:-?}" "${pid:-—}"
            else
                printf '%-50s (not loaded)\n' "$(basename "$p" .plist)"
            fi
        done
        ;;
    *)
        usage
        ;;
esac
