#!/bin/bash
# opp_ci-worker-run <name> — env-sourcing wrapper for a launchd worker.
#
# launchd has no equivalent of systemd's EnvironmentFile=, so the worker
# plist can't inject per-instance env vars from a file. This wrapper does
# what the systemd unit's two EnvironmentFile= lines do: source the shared
# env and the per-worker env, then exec the worker. Keeping the token in a
# 0600 file owned by opp_ci (rather than in the world-readable plist) means
# rotating it is just "edit the file + launchctl kickstart -k", no plist
# change. See doc/launchd.md and packaging/launchd/worker.plist.template.
set -euo pipefail

name="${1:?usage: opp_ci-worker-run <worker-name>}"

# `set -a` exports every variable a sourced file assigns, so the values
# reach the exec'd worker and the subprocesses it spawns (opp_env, nix).
# Precedence matches Linux: anything already in the environment (set by the
# plist's EnvironmentVariables) wins; these files only fill the gaps —
# the .env files use plain `KEY=value` lines, not `export`/override.
set -a
[ -f /etc/opp_ci/opp_ci.env ]          && . /etc/opp_ci/opp_ci.env
[ -f "/etc/opp_ci/workers/$name.env" ] && . "/etc/opp_ci/workers/$name.env"
set +a

# Coordinator URL + token now live in the environment; `worker start`
# reads $OPP_CI_COORDINATOR_URL / $OPP_CI_WORKER_TOKEN when given no flags.
exec /opt/opp_ci/.venv/bin/opp_ci worker start
