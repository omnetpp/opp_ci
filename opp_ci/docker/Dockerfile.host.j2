# Generated by `opp_ci image build --toolchain host`.
# Provides {{ compiler }}-{{ compiler_version }} from the base OS's package
# manager, plus the system libraries OMNeT++/INET needs at build time. The
# project source is bind-mounted at /work; opp_ci's "internal run-direct"
# entrypoint drives opp_repl in-process.
FROM {{ os }}:{{ os_version }}

ENV DEBIAN_FRONTEND=noninteractive
ENV LANG=C.UTF-8

{% if os in ("ubuntu", "debian") -%}
RUN apt-get update && apt-get install --no-install-recommends -y \
      ca-certificates curl git python3 python3-pip python3-venv \
      make pkg-config bison flex perl \
      libxml2-dev zlib1g-dev libssl-dev libpcap-dev \
      {{ compiler_package }} \
 && rm -rf /var/lib/apt/lists/*
# Ubuntu/Debian's '{{ compiler }}-{{ compiler_version }}' package only installs
# versioned binaries (/usr/bin/{{ compiler }}-{{ compiler_version }}). OMNeT++'s
# ./configure and opp_makemake call the unversioned names — provide aliases.
{% if compiler == "clang" -%}
RUN ln -sf /usr/bin/clang-{{ compiler_version }} /usr/local/bin/clang \
 && ln -sf /usr/bin/clang++-{{ compiler_version }} /usr/local/bin/clang++ \
 && ln -sf /usr/bin/clang-{{ compiler_version }} /usr/local/bin/cc \
 && ln -sf /usr/bin/clang++-{{ compiler_version }} /usr/local/bin/c++
{%- elif compiler == "gcc" -%}
RUN ln -sf /usr/bin/gcc-{{ compiler_version }} /usr/local/bin/gcc \
 && ln -sf /usr/bin/g++-{{ compiler_version }} /usr/local/bin/g++ \
 && ln -sf /usr/bin/gcc-{{ compiler_version }} /usr/local/bin/cc \
 && ln -sf /usr/bin/g++-{{ compiler_version }} /usr/local/bin/c++
{%- endif %}
{%- elif os == "fedora" -%}
RUN dnf -y install \
      ca-certificates curl git python3 python3-pip \
      make pkgconf-pkg-config bison flex perl \
      libxml2-devel zlib-devel openssl-devel libpcap-devel \
      {{ compiler_package }} \
 && dnf clean all
{%- else -%}
# Unknown base OS '{{ os }}'. Extend Dockerfile.host.j2 with package-manager
# commands for this distro before building images from it.
RUN false
{%- endif %}

# All three packages come from GitHub HEAD (PyPI's opp_env catalogue can lag
# behind — e.g. PyPI didn't know omnetpp-6.4.0 yet when this was written).
# SHAs are resolved at image-build time so a push invalidates the layer cache.
RUN python3 -m venv /opt/opp_ci_venv \
 && /opt/opp_ci_venv/bin/pip install --upgrade pip \
 && /opt/opp_ci_venv/bin/pip install \
        git+https://github.com/omnetpp/opp_env.git@{{ opp_env_ref }} \
        git+https://github.com/omnetpp/opp_repl.git@{{ opp_repl_ref }} \
        git+https://github.com/omnetpp/opp_ci.git@{{ opp_ci_ref }}
ENV PATH=/opt/opp_ci_venv/bin:$PATH

# Install OMNeT++ {{ omnetpp_version }} into a nixless opp_env workspace.
# Using --nixless-workspace means opp_env uses the apt-installed compiler
# and libs (which we picked above) rather than pulling Nix into the image.
RUN mkdir -p /opt/opp_env_workspace \
 && opp_env -l ERROR install --init --nixless-workspace \
        -w /opt/opp_env_workspace omnetpp-{{ omnetpp_version }}

# Entry wrapper: container is invoked with opp_ci args, but opp_repl needs
# OMNETPP_ROOT / PATH etc. set. 'opp_env run' does exactly that.
RUN cat > /opt/opp_ci_entry.sh <<'SCRIPT'
#!/bin/sh
exec opp_env -l ERROR run -w /opt/opp_env_workspace omnetpp-{{ omnetpp_version }} -c "opp_ci $*"
SCRIPT
RUN chmod +x /opt/opp_ci_entry.sh

WORKDIR /work
ENTRYPOINT ["/opt/opp_ci_entry.sh"]
