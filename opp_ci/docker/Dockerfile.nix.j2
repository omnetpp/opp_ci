# Generated by `opp_ci image build --toolchain nix`.
# Provides single-user Nix + opp_env, so the compiler and OMNeT++/INET deps
# come from Nix (compiler axis is implicit per opp_env's project options).
# The project source is bind-mounted at /work; the host's Nix store is
# mounted as a named volume at /nix to avoid rebuilding deps per run.
FROM {{ os }}:{{ os_version }}

ENV DEBIAN_FRONTEND=noninteractive
ENV LANG=C.UTF-8

{% if os in ("ubuntu", "debian") -%}
RUN apt-get update && apt-get install --no-install-recommends -y \
      ca-certificates curl git python3 python3-pip xz-utils sudo \
 && rm -rf /var/lib/apt/lists/*
{%- elif os == "fedora" -%}
RUN dnf -y install ca-certificates curl git python3 python3-pip xz sudo \
 && dnf clean all
{%- else -%}
RUN false
{%- endif %}

# Single-user Nix install. /nix is a mount point — the actual store comes from
# a docker named volume so it survives across container instances.
RUN sh <(curl -L https://nixos.org/nix/install) --no-daemon
ENV PATH=/root/.nix-profile/bin:$PATH
ENV NIX_PATH=nixpkgs=channel:nixos-unstable

RUN pip3 install opp_env

WORKDIR /work
ENTRYPOINT ["opp_env"]
