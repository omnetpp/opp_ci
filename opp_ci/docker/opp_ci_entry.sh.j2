#!/bin/sh
# Generated by opp_ci image build. Runs at every container start.
# 1. Clone (or fetch) opp_ci and opp_repl into /opt/<name>_src so a push
#    to either repo is picked up without rebuilding this image.
# 2. pip install -e them into the venv (idempotent — fast no-op when nothing
#    changed, since the egg-link is already present).
# 3. Exec via 'opp_env run' so OMNETPP_ROOT / PATH / etc. are set up.
set -e

sync_repo() {
    name=$1
    url=$2
    dir=/opt/${name}_src
    if [ ! -d "$dir/.git" ]; then
        git clone --depth 50 "$url" "$dir"
    else
        git -C "$dir" fetch --depth 50 origin
        git -C "$dir" reset --hard origin/HEAD
    fi
}

sync_repo opp_ci   https://github.com/omnetpp/opp_ci.git
sync_repo opp_repl https://github.com/omnetpp/opp_repl.git

pip install -q -e /opt/opp_ci_src /opt/opp_repl_src

exec opp_env -l ERROR run -w /opt/opp_env_workspace omnetpp-{{ omnetpp_version }} -c "opp_ci $*"
