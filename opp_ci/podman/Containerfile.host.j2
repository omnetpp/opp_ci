# Generated by `opp_ci image build --toolchain host`.
# Provides {{ compiler }}-{{ compiler_version }} from the base OS's package
# manager, plus the system libraries OMNeT++/INET needs at build time. The
# project source is bind-mounted at /work; opp_ci's "internal run-direct"
# entrypoint drives opp_repl in-process.
#
# opp_env is baked into the image (it changes rarely); opp_ci and opp_repl
# are *not* — the entrypoint clones them at container start and pip-installs
# them in editable mode, so a push to either repo does not invalidate this
# image's layers. The clone path is /opt/opp_ci_src and /opt/opp_repl_src;
# mount a podman named volume there to persist the clones across runs.
FROM {{ os }}:{{ os_version }}

ENV DEBIAN_FRONTEND=noninteractive
ENV LANG=C.UTF-8

{% if os in ("ubuntu", "debian") -%}
# Mirrors opp_env's OMNeT++ project description (database/omnetpp.py) — the
# nix_packages list translated to apt names. Covers 5.x and 6.x; Qt6 + lldb
# are 6.2+ (harmless on older runs since opp_env only invokes what it needs).
RUN apt-get update && apt-get install --no-install-recommends -y \
      ca-certificates curl git which xdg-utils \
      make pkg-config bison flex perl ccache lldb \
      python3 python3-dev python3-pip python3-venv \
      libxml2-dev zlib1g-dev libssl-dev libpcap-dev \
      libexpat1-dev libdwarf-dev libelf-dev \
      qt6-base-dev libqt6svg6-dev \
      {{ compiler_package }} \
 && rm -rf /var/lib/apt/lists/*
# Ubuntu/Debian's '{{ compiler }}-{{ compiler_version }}' package only installs
# versioned binaries (/usr/bin/{{ compiler }}-{{ compiler_version }}). OMNeT++'s
# ./configure and opp_makemake call the unversioned names — provide aliases.
{% if compiler == "clang" -%}
RUN ln -sf /usr/bin/clang-{{ compiler_version }} /usr/local/bin/clang \
 && ln -sf /usr/bin/clang++-{{ compiler_version }} /usr/local/bin/clang++ \
 && ln -sf /usr/bin/clang-{{ compiler_version }} /usr/local/bin/cc \
 && ln -sf /usr/bin/clang++-{{ compiler_version }} /usr/local/bin/c++
{%- elif compiler == "gcc" -%}
RUN ln -sf /usr/bin/gcc-{{ compiler_version }} /usr/local/bin/gcc \
 && ln -sf /usr/bin/g++-{{ compiler_version }} /usr/local/bin/g++ \
 && ln -sf /usr/bin/gcc-{{ compiler_version }} /usr/local/bin/cc \
 && ln -sf /usr/bin/g++-{{ compiler_version }} /usr/local/bin/c++
{%- endif %}
{%- elif os == "fedora" -%}
RUN dnf -y install \
      ca-certificates curl git which xdg-utils \
      make pkgconf-pkg-config bison flex perl ccache lldb \
      python3 python3-devel python3-pip \
      libxml2-devel zlib-devel openssl-devel libpcap-devel \
      expat-devel libdwarf-devel elfutils-devel \
      qt6-qtbase-devel qt6-qtsvg-devel \
      {{ compiler_package }} \
 && dnf clean all
{%- else -%}
# Unknown base OS '{{ os }}'. Extend Containerfile.host.j2 with package-manager
# commands for this distro before building images from it.
RUN false
{%- endif %}

# opp_env and opp_repl's third-party deps ([all] extras: matplotlib, numpy,
# scipy, …) are baked in. opp_ci and opp_repl *code* is still cloned at
# container start by the entrypoint and editable-installed over the baked deps,
# so a push to opp_ci/opp_repl is picked up without rebuilding this image; a
# push that changes opp_env's SHA or adds a new opp_repl dependency needs a rebuild.
RUN python3 -m venv /opt/opp_ci_venv \
 && /opt/opp_ci_venv/bin/pip install --upgrade pip \
 && /opt/opp_ci_venv/bin/pip install \
        git+https://github.com/omnetpp/opp_env.git@{{ opp_env_ref }} \
        "opp_repl[all] @ git+https://github.com/omnetpp/opp_repl.git"
ENV PATH=/opt/opp_ci_venv/bin:$PATH

# Install OMNeT++ {{ omnetpp_version }} into a nixless opp_env workspace.
# Using --nixless-workspace means opp_env uses the apt-installed compiler
# and libs (which we picked above) rather than pulling Nix into the image.
RUN mkdir -p /opt/opp_env_workspace \
 && opp_env -l ERROR install --init --nixless-workspace \
        -w /opt/opp_env_workspace omnetpp-{{ omnetpp_version }}

# Entry wrapper: container is invoked with opp_ci args. The script clones
# opp_ci + opp_repl on each run and pip-installs them in editable mode
# before exec'ing `opp_env run`. See opp_ci_entry.sh.j2 for details. The
# script is rendered separately and shipped into the build context — the
# legacy builder doesn't process shell heredocs inside RUN, so an
# inline `cat > … <<'EOF'` would produce a 0-byte file.
COPY opp_ci_entry.sh /opt/opp_ci_entry.sh
RUN chmod +x /opt/opp_ci_entry.sh

WORKDIR /work
ENTRYPOINT ["/opt/opp_ci_entry.sh"]
