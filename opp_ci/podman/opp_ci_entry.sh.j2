#!/bin/sh
# Generated by opp_ci image build.
#
# Stages (the worker drives these as separate `podman exec`s; see
# executor._run_test_in_podman):
#   --bootstrap-only             clone/fetch opp_repl + pip install, exit.
#   --skip-bootstrap --do-install
#                                opp_env-install the catalog project(s), then
#                                exit — the "Install dependencies" stage.
#   --skip-bootstrap …           skip clone/pip AND install (already done); cd
#                                into the installed project dir and `opp_env
#                                run` the rest (Compile / Run tests stages).
#   (no flag)                    bootstrap + install + run, legacy single-shot.
#
# run_cmd prints each meaningful command, prefixed with a marker the worker
# recognises and shows as a coloured "command" line in the stage view (see
# _run_podman_staged) — so the captured log shows what ran, not a `set -x`
# dump of every shell builtin.
set -e

run_cmd() {
    printf '@@oppci:cmd@@ %s\n' "$*"
    "$@"
}

# `opp_env install` accepts a "<project>@<ref>" token (it clones and checks out
# that git ref). `opp_env run` REJECTS it ("Git branch may only be specified
# when the project is installed") unless --install is also passed. The deps and
# project are already installed (the deps.install stage), so the run only needs
# their versioned ids — strip any "@<ref>" suffix from each token. Tokens
# without an "@" pass through unchanged.
strip_refs() {
    _out=""
    for _t in $1; do
        _out="$_out ${_t%@*}"
    done
    printf '%s' "$_out"
}

sync_repo() {
    name=$1
    url=$2
    ref=${3:-HEAD}
    dir=/opt/${name}_src
    if [ ! -d "$dir/.git" ]; then
        run_cmd git clone --depth 50 --branch "$ref" "$url" "$dir"
    else
        run_cmd git -C "$dir" fetch --depth 50 origin "$ref"
        run_cmd git -C "$dir" reset --hard FETCH_HEAD
    fi
}

# Only opp_repl is cloned/installed — the tests run opp_repl's console scripts
# directly (opp_build_project, opp_run_*_tests), not opp_ci. See plan §2.6.
do_bootstrap() {
    sync_repo opp_repl {{ opp_repl_repo }} {{ opp_repl_ref }}
    run_cmd pip install -q -e /opt/opp_repl_src
}

# Parse OPP_CI_INSTALL_PROJECTS (comma-separated catalog projects) into
# FIRST_PROJECT (for the cwd cd) and EXTRA_PROJECTS (space-separated, passed to
# `opp_env run`). Recomputed on every exec — cheap, env-only.
parse_projects() {
    EXTRA_PROJECTS=""
    FIRST_PROJECT=""
    [ -z "$OPP_CI_INSTALL_PROJECTS" ] && return 0
    IFS=','
    for p in $OPP_CI_INSTALL_PROJECTS; do
        p=$(echo "$p" | tr -d ' ')
        [ -z "$p" ] && continue
        # FIRST_PROJECT is only used to cd into the install dir, whose name has
        # no "@<ref>" — strip it. EXTRA_PROJECTS keeps the ref for the install.
        [ -z "$FIRST_PROJECT" ] && FIRST_PROJECT="${p%@*}"
        EXTRA_PROJECTS="$EXTRA_PROJECTS $p"
    done
    unset IFS
}

# Install each catalog project into the shared workspace. Runs ONCE, in the
# Install dependencies stage (--do-install) — not on every build/test exec.
# $OPP_CI_PIN_DEPS pins dependency versions (e.g. omnetpp-6.2.0) so opp_env
# builds the exact versions the run requested and reuses the baked omnetpp.
do_deps_install() {
    for p in $EXTRA_PROJECTS; do
        run_cmd opp_env -l ERROR install -w /opt/opp_env_workspace "$p" $OPP_CI_PIN_DEPS
    done
}

# cd into the first installed project's dir — opp_repl auto-discovers the
# project from cwd. No-op for a bind-mounted SimulationProject (no catalog
# install), which stays in /work.
enter_workdir() {
    [ -z "$FIRST_PROJECT" ] && return 0
    if [ -d "/opt/opp_env_workspace/$FIRST_PROJECT" ]; then
        cd "/opt/opp_env_workspace/$FIRST_PROJECT"
    else
        # A "-latest"/"-git" alias resolves to a versioned dir; glob the bare name.
        prefix=$(echo "$FIRST_PROJECT" | sed -E "s/-(latest|git|[0-9].*)$//")
        workdir=$(ls -d /opt/opp_env_workspace/${prefix}*/ 2>/dev/null | head -1)
        [ -n "$workdir" ] && cd "$workdir"
    fi
}

LEGACY=""
case "$1" in
    --bootstrap-only) do_bootstrap; exit 0 ;;
    --skip-bootstrap) shift ;;
    *)                do_bootstrap; LEGACY=1 ;;
esac

parse_projects

# The Install dependencies stage: install the catalog project(s), then exit.
if [ "$1" = "--do-install" ]; then
    do_deps_install
    exit 0
fi

# Legacy single-shot path installs inline (option (b) does it as its own stage).
[ -n "$LEGACY" ] && do_deps_install

enter_workdir

# The run command must name omnetpp (and any other pinned deps) so opp_env sets
# up the matching environment. Prefer the run's pins ($OPP_CI_PIN_DEPS); fall
# back to the omnetpp baked into this image when the run carried no pins.
# "$*" is the opp_repl console command the worker passed (opp_build_project /
# opp_run_*_tests with its --load/-p flags); opp_env runs it in the project env.
PINNED_PROJECTS="${OPP_CI_PIN_DEPS:-{{ omnetpp_install }}}"
# Drop "@<ref>" suffixes: the run stage has no --install, so opp_env rejects
# branch tokens. The deps.install stage already checked out the right refs.
RUN_PINNED=$(strip_refs "$PINNED_PROJECTS")
RUN_EXTRA=$(strip_refs "$EXTRA_PROJECTS")
printf '@@oppci:cmd@@ opp_env -l ERROR run -w /opt/opp_env_workspace %s%s -c "%s"\n' "$RUN_PINNED" "$RUN_EXTRA" "$*"
exec opp_env -l ERROR run -w /opt/opp_env_workspace $RUN_PINNED $RUN_EXTRA -c "$*"
