# Generated by `opp_ci image build --toolchain nix`.
# Provides single-user Nix + opp_env. The compiler and project deps
# (omnetpp, ffmpeg, z3, …) come from Nix per opp_env's catalog, so the
# image does *not* need apt packages tailored to any one project.
# The project source (for SimulationProject runs) is bind-mounted at /work.
# For opp_env catalog runs no source mount is needed — opp_env's --install
# downloads the project from its catalog source.
#
# Persistent state:
#   /nix  — Nix store; mount the podman named volume 'opp-ci-nix-store' here
#           so downloaded deps survive across container instances.
#
# This is the omnetpp-AGNOSTIC base image. The per-omnetpp runner image
# (opp-ci-runner:<slug>-nix-omnetpp-<ver>) is produced by running
# 'opp_env install omnetpp-<ver>' in a container of this base with the
# 'opp-ci-nix-store' volume mounted, then 'podman commit' — which excludes the
# volume, so the compiled workspace lands in the image while the Nix store
# stays in the volume (see executor._build_nix_runner_image).
#
# WARNING: a baked runner image references /nix/store/<hash> paths that live
# in the 'opp-ci-nix-store' volume, NOT in the image. Do NOT run
# nix-collect-garbage on that volume — GC would remove paths not held by a
# gcroot and silently break every baked image. Rebuild images after any GC.
#
# The entrypoint clones opp_repl on each start (same pattern as
# Containerfile.host.j2) so a push to its opp_ci branch does not invalidate
# this image's layers; only changes to opp_env's pinned SHA do.
FROM {{ os }}:{{ os_version }}

ENV DEBIAN_FRONTEND=noninteractive
ENV LANG=C.UTF-8

{% if os in ("ubuntu", "debian") -%}
# iputils-ping + strip its cap_net_raw so a rootless userns can execve it: INET's
# ExternalProcess tests run `ping`; a missing or cap-bearing ping makes execvp fail and
# the forked child's stopProcess() do `/bin/kill -SIGTERM 0` — a process-group SIGTERM
# that kills the whole concurrent run. See Containerfile.host.j2 for the full details.
RUN apt-get update && apt-get install --no-install-recommends -y \
      ca-certificates curl git python3 python3-dev python3-pip python3-venv \
      xz-utils sudo iputils-ping psmisc libcap2-bin \
 && rm -rf /var/lib/apt/lists/*
{%- elif os == "fedora" -%}
RUN dnf -y install ca-certificates curl git python3 python3-devel python3-pip xz sudo iputils psmisc libcap \
 && dnf clean all
{%- else -%}
RUN false
{%- endif %}
# Strip ping's cap_net_raw (see above); no-op if ping/setcap absent.
RUN setcap -r /usr/bin/ping 2>/dev/null || true

# Single-user Nix install via Determinate Systems' nix-installer, which
# explicitly supports container builds (no systemd / no init / no nixbld
# users required) — the upstream nix.org installer fails in this image
# because it expects a 'nixbld' build-users-group even in --no-daemon mode.
#
# /nix is a mount point — the actual store comes from a podman named
# volume so deps survive across container instances.
RUN curl --proto '=https' --tlsv1.2 -sSf -L \
        https://install.determinate.systems/nix \
        -o /tmp/nix-install.sh \
 && sh /tmp/nix-install.sh install linux \
        --init none \
        --no-confirm \
        --extra-conf "sandbox = false" \
 && rm /tmp/nix-install.sh
ENV PATH=/nix/var/nix/profiles/default/bin:/root/.nix-profile/bin:$PATH
ENV NIX_PATH=nixpkgs=channel:nixos-unstable

# Only opp_env is baked in. opp_repl is cloned at container start by the
# entrypoint — see opp_env_entry.sh.j2. opp_ci is not used inside the image.
RUN python3 -m venv /opt/opp_ci_venv \
 && /opt/opp_ci_venv/bin/pip install --upgrade pip \
 && /opt/opp_ci_venv/bin/pip install \
        git+https://github.com/omnetpp/opp_env.git@{{ opp_env_ref }}
ENV PATH=/opt/opp_ci_venv/bin:$PATH

# Pre-initialise a workspace so 'opp_env install' / 'opp_env run --install'
# inside the container has somewhere to put the project metadata.
RUN mkdir -p /opt/opp_env_workspace \
 && opp_env -l ERROR init -w /opt/opp_env_workspace

COPY opp_env_entry.sh /opt/opp_env_entry.sh
RUN chmod +x /opt/opp_env_entry.sh

WORKDIR /work
ENTRYPOINT ["/opt/opp_env_entry.sh"]
