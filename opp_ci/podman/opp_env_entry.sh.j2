#!/bin/sh
# Entrypoint for the Nix-flavoured runner image. Runs at every container
# start. Mirrors opp_ci_entry.sh.j2 but defers project + omnetpp install
# to Nix (via 'opp_env run --install ...' inside the container) instead of
# opp_env --nixless-workspace, so the image stays project-agnostic.
#
#   1. Clone (or fetch) opp_ci and opp_repl into /opt/<name>_src so a push
#      to either repo is picked up without rebuilding this image.
#   2. pip install -e them so opp_build_project, opp_run_smoke_tests, etc.
#      land on PATH inside the venv.
#   3. Exec opp_env directly with the args the worker passed (typically
#      'run --install <project> -c "<opp_repl_command>"').
#
# run_cmd prints each meaningful command, prefixed with a marker the worker
# recognises and shows as a coloured "command" line in the stage view (see
# _run_podman_staged) — so the captured log shows what ran, not a `set -x`
# dump of every shell builtin.
set -e

run_cmd() {
    printf '@@oppci:cmd@@ %s\n' "$*"
    "$@"
}

sync_repo() {
    name=$1
    url=$2
    dir=/opt/${name}_src
    if [ ! -d "$dir/.git" ]; then
        run_cmd git clone --depth 50 "$url" "$dir"
    else
        run_cmd git -C "$dir" fetch --depth 50 origin
        run_cmd git -C "$dir" reset --hard origin/HEAD
    fi
}

do_bootstrap() {
    sync_repo opp_ci   https://github.com/omnetpp/opp_ci.git
    sync_repo opp_repl https://github.com/omnetpp/opp_repl.git
    run_cmd pip install -q -e /opt/opp_ci_src /opt/opp_repl_src
}

# Stages, driven as separate `podman exec`s by the worker (see
# executor._run_test_in_podman):
#   --bootstrap-only  clone/fetch + pip install, then exit (run once)
#   --skip-bootstrap  skip the clone/pip and exec opp_env with the rest
#   (no flag)         bootstrap + exec opp_env, the legacy single-shot path
case "$1" in
    --bootstrap-only) do_bootstrap; exit 0 ;;
    --skip-bootstrap) shift ;;
    *)                do_bootstrap ;;
esac

# opp_env's -w is a per-subcommand option, not a top-level flag, so cd
# into the workspace and let opp_env auto-detect it from cwd.
# No command marker: the Compile/Run-tests stage already shows a clean
# headline, and the raw `opp_env run … -c "…"` would just duplicate it.
cd /opt/opp_env_workspace
exec opp_env -l ERROR "$@"
