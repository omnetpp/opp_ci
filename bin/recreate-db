#!/bin/bash
#
# Recreate the opp_ci database from scratch:
# - Seed Tier 1 projects and default matrices
# - Import Tier 2 projects from opp_env catalog
#

set -e

opp_ci reset-db --yes --preserve-tokens
opp_ci seed-projects
opp_ci seed-platforms
opp_ci seed-matrices
opp_ci sync-catalog
opp_ci token list | grep -qE '^\S+\s+notes-readonly\b' || opp_ci token create --name notes-readonly --role readonly
opp_ci list-projects
