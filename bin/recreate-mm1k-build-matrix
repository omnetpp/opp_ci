#!/bin/bash
#
# Add the mm1k project and its build matrices to the database.
#
# Creates three matrices:
#   mm1k-master          build+smoke on master
#   mm1k-topic           build+smoke on the topic branch
#   mm1k-master-to-topic build for each commit in master..topic
#

set -e

COMMON=(--project mm1k --os "Ubuntu 24.04" --compiler gcc-13 --opp-file /home/levy/workspace/mm1k/mm1k.opp --replace)

opp_ci add-project --name mm1k --github levy/mm1k --git-url https://github.com/levy/mm1k.git --deps omnetpp || true
opp_ci create-matrix --name mm1k-master          "${COMMON[@]}" --tests build,smoke,opp --refs master
opp_ci create-matrix --name mm1k-topic            "${COMMON[@]}" --tests build,smoke,opp --refs topic
opp_ci create-matrix --name mm1k-master-to-topic  "${COMMON[@]}" --tests build,smoke,opp --ref-range master..topic
